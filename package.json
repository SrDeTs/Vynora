{
  "name": "vynora",
  "private": true,
  "version": "1.0.0",
  "description": "Premium iPod CoverFlow clone with iTunes API integration",
  "author": "Michael <michael@example.com>",
  "homepage": "https://github.com/vynora/app",
  "main": "electron-main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:debug": "./debug.sh",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build-win": "npm run build && electron-builder --win",
    "electron:build-all": "npm run build && electron-builder --linux --win",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open-android": "CAPACITOR_ANDROID_STUDIO_PATH=/opt/android-studio/bin/studio.sh npx cap open android",
    "cap:build-android": "npm run cap:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "framer-motion": "^12.36.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "music-metadata": "^11.12.3",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.vynora.app",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js"
    ],
    "asar": true
  }
}
