{
  "name": "vynora",
  "private": true,
  "version": "1.0.0",
  "description": "Premium iPod CoverFlow clone with iTunes API integration",
  "author": "Michael <michael@example.com>",
  "homepage": "https://github.com/vynora/app",
  "main": "electron-main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:debug": "./debug.sh",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build-win": "npm run build && electron-builder --win",
    "electron:build-all": "npm run build && electron-builder --linux --win"
  },
  "dependencies": {
    "music-metadata": "^11.12.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.1",
    "electron-builder": "^24.13.3",
    "framer-motion": "^12.36.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.vynora.app",
    "linux": {
      "category": "AudioVideo",
      "maintainer": "Michael <michael@example.com>",
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb",
        "pacman",
        "zip"
      ],
      "executableArgs": [
        "--no-sandbox"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "package.json",
      "Vynora.png",
      "node_modules/music-metadata/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/music-metadata"
    ],
    "electronLanguages": ["pt-BR", "en-US"]
  }
}
